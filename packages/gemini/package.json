{
  "name": "@zagents/gemini",
  "version": "0.1.1",
  "description": "Algorithmic Agent Gemini (ADR-047) — a deterministic control plane that wraps any model/tool/skill as a replaceable worker: utility-scored decisions, four-gate safety, hash-chained receipts, circuit-breaker recovery, adversarial verification, and a bandit agent pool. The model proposes, the gemini decides, the algorithms verify.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "agent-gemini",
    "control-plane",
    "zagents",
    "receipts",
    "verification",
    "circuit-breaker",
    "contextual-bandit",
    "consensus",
    "governance"
  ],
  "author": "rUv <ruv@ruv.net>",
  "license": "MIT",
  "homepage": "https://github.com/cvsz/zagents-generator",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cvsz/zagents-generator.git",
    "directory": "packages/gemini"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
