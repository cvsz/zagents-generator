  "description": "Shared contract for @zagents/vertical-* packs — VerticalPack interface, manifest schema, template-files protocol",
  "homepage": "https://github.com/cvsz/zagents-generator",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cvsz/zagents-generator.git",
    "directory": "packages/vertical-base"
  },
