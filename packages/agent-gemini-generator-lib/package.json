{
  "name": "@ruvnet/agent-gemini-generator",
  "version": "0.1.3",
  "description": "Library/core package for the Agent Gemini Generator. Pair with `metaharness` for the CLI. Re-exports scaffold(), validate(), and the deterministic-analysis pipeline from `metaharness` so consumers can `import { scaffold } from '@ruvnet/agent-gemini-generator'` without shelling out to the CLI.",
  "homepage": "https://github.com/ruvnet/agent-gemini-generator",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruvnet/agent-gemini-generator.git",
    "directory": "packages/agent-gemini-generator-lib"
  },
  "license": "MIT",
  "author": "rUv <ruv@ruv.net>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "agent-gemini",
    "agent-gemini-generator",
    "metaharness",
    "scaffold",
    "mcp-server",
    "claude-code",
    "codex",
    "library"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "metaharness": "0.1.5"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
