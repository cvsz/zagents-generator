{
  "permissions": {
    "allow": [
      "Bash(npx {{name}}*)",
      "mcp__{{name}}__*",
      "mcp__mastery_log__*",
      "mcp__curriculum__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(rm -rf*)",
      "Bash(git push*)"
    ]
  },
  "mcpServers": {
    "{{name}}": {
      "command": "npx",
      "args": [
        "-y",
        "{{name}}@latest",
        "mcp",
        "start"
      ]
    },
    "mastery_log": {
      "command": "npx",
      "args": [
        "-y",
        "{{name}}@latest",
        "mcp",
        "mastery"
      ]
    },
    "curriculum": {
      "command": "npx",
      "args": [
        "-y",
        "{{name}}@latest",
        "mcp",
        "curriculum"
      ]
    }
  }
}
