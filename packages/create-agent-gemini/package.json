{
  "name": "zagents",
  "version": "0.2.2",
  "description": "ZAgents — mint a custom AI agent gemini from any repo. Browser Studio + `npx zagents` CLI. Runs on Claude Code, Codex, pi.dev, Hermes, OpenClaw, RVM.",
  "homepage": "https://github.com/cvsz/zagents-generator",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cvsz/zagents-generator.git",
    "directory": "packages/create-agent-gemini"
  },
  "license": "MIT",
  "author": "rUv <ruv@ruv.net>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "zagents": "dist/bin.js",
    "gemini": "dist/gemini-bin.js"
  },
  "files": [
    "dist/**",
    "templates/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit",
    "gen:templates": "node scripts/gen-templates.mjs"
  },
  "keywords": [
    "zagents",
    "agent-gemini",
    "zagents-generator",
    "ai-agent",
    "ai-agent-scaffold",
    "ai-agent-cli",
    "agentic-ai",
    "agentic-workflow",
    "autonomous-agents",
    "multi-agent",
    "multi-agent-framework",
    "repo-to-agent",
    "code-agent",
    "coding-agent",
    "github-agent",
    "scaffold",
    "scaffolder",
    "boilerplate",
    "cli",
    "create-agent",
    "create-app",
    "npx",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "claude-code",
    "claude-code-plugin",
    "anthropic",
    "openai",
    "codex",
    "openai-codex",
    "pi-dev",
    "hermes-agent",
    "openclaw",
    "rvm",
    "rust",
    "wasm",
    "wasm-bindgen",
    "napi-rs",
    "typescript",
    "ed25519",
    "witness",
    "provenance",
    "slsa",
    "sbom",
    "spdx",
    "gcp-secret-manager",
    "ipfs",
    "agent-orchestration",
    "agent-runtime",
    "agent-factory",
    "vertical-ai",
    "ai-tooling"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "kolorist": "^1.8.0",
    "prompts": "^2.4.2",
    "@zagents/darwin": "^0.2.5"
  },
  "peerDependencies": {
    "@zagents/kernel": "^0.1.2"
  },
  "peerDependenciesMeta": {
    "@zagents/kernel": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "optionalDependencies": {
    "@ruvector/ruvllm": "^2.5.6"
  }
}
